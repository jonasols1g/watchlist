rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/watchlistItems/{mediaId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Feedback-innsending (issue #40, se
    // docs/plans/feedback-innsending-og-automatisk-oppfolging.md#del-a) —
    // IKKE brukerbundet, åpen lesing (konsistent med appens allerede åpne
    // tillitsmodell: anonym auth, ingen ekte kontoer, ingen sensitiv info i
    // tilbakemeldinger). Append-only: ingen update/delete.
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000
        && request.resource.data.score is int
        && request.resource.data.score >= 1
        && request.resource.data.score <= 5;
      allow update, delete: if false;
    }
  }
}
